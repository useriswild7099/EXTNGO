{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/(solutions|tech|industries|Warranty|FAQ|Support|contact|about|blog|careers|terms|privacy|warranty-policy)",
      "destination": "/index.html"
    },
    {
      "source": "/_next/data/:path*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/frames/png/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
