{"pageProps":{"techData":{"id":"aUEuzBAAACIAx9KG","uid":null,"url":"/tech","type":"tech","href":"https://EXTNGO.cdn.prismic.io/api/v2/documents/search?ref=aa6GrxIAACIArDv7&q=%5B%5B%3Ad+%3D+at%28document.id%2C+%22aUEuzBAAACIAx9KG%22%29+%5D%5D","tags":[],"first_publication_date":"2025-12-16T10:08:53+0000","last_publication_date":"2026-02-16T08:11:57+0000","slugs":["tech"],"linked_documents":[],"lang":"en-us","alternate_languages":[],"data":{"hero_title_main":"Rapid Tow Shearing \nTechnology","hero_text":[],"hero_video_desktop":{"link_type":"Media","key":"02ac360c-424f-4397-af5c-d3c5b59ce1e4","kind":"file","id":"aWEfyAIvOtkhBOsl","url":"https://EXTNGO.cdn.prismic.io/EXTNGO/aWEfyAIvOtkhBOsl_EXTNGO-TECHHEROVIDEO_1.mp4","name":"hero-tech.mp4","size":"2214760"},"hero_video_mobile":{"link_type":"Media","key":"6c47cc13-bcd0-4e79-8839-ecbf5d322639","kind":"file","id":"aWEfyAIvOtkhBOsl","url":"https://EXTNGO.cdn.prismic.io/EXTNGO/aWEfyAIvOtkhBOsl_EXTNGO-TECHHEROVIDEO_1.mp4","name":"hero-tech.mp4","size":"2214760"},"hero_poster":{"dimensions":{"width":1920,"height":1080},"alt":null,"copyright":null,"url":"https://images.prismic.io/EXTNGO/aWEZ2QIvOtkhBOox_EXTNGO-TECHHEROVIDEO.webp?auto=format,compress","id":"aWEZ2QIvOtkhBOox","edit":{"x":0,"y":0,"zoom":1,"background":"transparent"}},"hero_text_mode":"white","paradigm_title":"Paradigm Shift in Composites","paradigm_items":[{"main_title":"Straight-Fiber Composite.","sub_title":"Heavy, expensive, limited.","first_paragraph":"Today parts are built by stacking straight-fiber layers at different angles to balance the properties at all directions, but structures are never loaded equally in all directions","second_paragraph":null},{"main_title":"Steered Fiber Composite.","sub_title":"Not possible before.","first_paragraph":"It would be far more efficient to design/manufacture by steering fibers to reinforce critical areas.\nThis results in lighter parts produced at lower cost, while paving the way for true industrial automation in composites.","second_paragraph":"50 years of academic literature highlight why fiber steering is the way we should be designing and manufacturing using composites, but manufacturing such structures without defects was impossible, until now…."}],"center_heading_text":"EXTNGO has unlocked Fiber \nSteering for the First Time","video_title":[{"type":"paragraph","text":"World’s first only defect-free steering technology, enabling production of fiber steered structures at industrial scale","spans":[],"direction":"ltr"}],"video_desktop":{"link_type":"Media"},"video_mobile":{"link_type":"Media"},"video_poster":{},"video_static_image":{"dimensions":{"width":2560,"height":1658},"alt":"Engineering Without Limits","copyright":null,"url":"https://images.prismic.io/EXTNGO/aWdb5QIvOtkhBfFB_Section.webp?auto=format,compress","id":"aWdb5QIvOtkhBfFB","edit":{"x":0,"y":0,"zoom":1,"background":"transparent"}},"video_thumbnail_image":{},"video_name":null,"advantage_section_line1":null,"advantage_section_line2":"Lightest Structures Possible","align_fibers_title":"Aligning the fibers with the primary load path of a structure leads to unparalleled structural efficiency.","align_fibers_heading_paragraph":"Best to illustrate the structural benefits with an example: assume the lower wing skin of an aircraft.","align_fibers_paragraph":"The wing is loaded in bending and ideally most of the fibers are running along its length – however the necessity for multiple large access holes, results in cut fibers and large stress concentrations. This requires significant additional material to reinforce the neighboring areas.","align_fibers_image":{"dimensions":{"width":1384,"height":786},"alt":null,"copyright":null,"url":"https://images.prismic.io/EXTNGO/aWdrCAIvOtkhBfRh_fibers.png?auto=format,compress","id":"aWdrCAIvOtkhBfRh","edit":{"x":0,"y":0,"zoom":1,"background":"transparent"}},"align_fibers_image_caption_1":"Representative structure (wing skin) found in defense and civil aircraft","align_fibers_image_caption_2":"Plot highlighting stress concentrations (red)","align_fibers_heading_paragraph_2":"By steering the fibers around the holes, the stress concentrations in these areas are eliminated, leading to a drastically lighter structure, when compared to the existing straight fiber design.","align_fibers_paragraph_2":"This also positively impacts the production cost, as significantly less carbon layers are needed (less raw material, less layup time).","align_fibers_video_image":{"dimensions":{"width":1380,"height":1380},"alt":"RTS tapes deposited around a hole","copyright":null,"url":"https://images.prismic.io/EXTNGO/aVKmb3NYClf9orYW_4.png?auto=format,compress","id":"aVKmb3NYClf9orYW","edit":{"x":0,"y":0,"zoom":1,"background":"transparent"}},"align_fibers_video_image_caption":"RTS tapes deposited around a hole","align_fibers_video":{"link_type":"Media","key":"372033fa-74c1-4ec4-92cb-54041de04d1a","kind":"file","id":"aWZYKAIvOtkhBcl1","url":"https://EXTNGO.cdn.prismic.io/EXTNGO/aWZYKAIvOtkhBcl1_TECH-RTSTAPEHOLEA03_1.mp4","name":"tech-rts.mp4","size":"386493"},"align_fibers_table_data":{"body":{"rows":[{"key":"5814f1af-b2a0-4c08-af36-b3c530a32d98","cells":[{"key":"f1012f45-3dc3-4d2e-a205-a8c32896637a","type":"data","content":[{"type":"paragraph","text":"Laminate","spans":[],"direction":"ltr"}]},{"key":"546a11ea-eb5a-4f67-8800-414e61475331","type":"data","content":[{"type":"paragraph","text":"Load (kN)","spans":[],"direction":"ltr"}]},{"key":"5eee9d87-869f-418d-a86f-459675a7862e","type":"data","content":[{"type":"paragraph","text":"Mass (kg)","spans":[],"direction":"ltr"}]},{"key":"515910c2-f128-4675-8244-3befeaa53e79","type":"data","content":[{"type":"paragraph","text":"Tsai-Wu failure criterion","spans":[],"direction":"ltr"}]},{"key":"196537c7-3175-4ffc-b9e1-5dcf411c79d1","type":"data","content":[{"type":"paragraph","text":"Load / Mass (kN/kg)","spans":[],"direction":"ltr"}]}]},{"key":"2091ee5f-94b9-45b4-8ee7-bb70eddc2293","cells":[{"key":"db9f4e91-12fa-4345-b2d4-691291e33ce1","type":"data","content":[{"type":"paragraph","text":"Quasi-isotropic (24 plies)","spans":[],"direction":"ltr"}]},{"key":"6221b028-9281-4e7d-acd3-084894deb122","type":"data","content":[{"type":"paragraph","text":"358","spans":[],"direction":"ltr"}]},{"key":"e983605a-1b62-4d0d-aefd-9b69f0527117","type":"data","content":[{"type":"paragraph","text":"3.71","spans":[],"direction":"ltr"}]},{"key":"52aa9fad-5776-473c-a999-e4c99d813e37","type":"data","content":[{"type":"paragraph","text":"1.001","spans":[],"direction":"ltr"}]},{"key":"93872251-f217-4e63-bf80-9550a01b0b00","type":"data","content":[{"type":"paragraph","text":"96.5","spans":[],"direction":"ltr"}]}]},{"key":"6283845d-0540-46ff-9bba-7be65bfdf242","cells":[{"key":"2fd299c6-25fd-45fa-a6bf-25b4745e4b51","type":"data","content":[{"type":"paragraph","text":"RTS (8 plies)","spans":[],"direction":"ltr"}]},{"key":"c93c8823-dd98-46d4-90c6-2b0e5ac91a3c","type":"data","content":[{"type":"paragraph","text":"358","spans":[],"direction":"ltr"}]},{"key":"94ddcdca-8a82-442c-b6b5-1f2826f721f9","type":"data","content":[{"type":"paragraph","text":"1.30","spans":[{"start":0,"end":4,"type":"strong"}],"direction":"ltr"}]},{"key":"c1cde4db-af8f-4186-a35a-e1c1e3491751","type":"data","content":[{"type":"paragraph","text":"0.8969","spans":[],"direction":"ltr"}]},{"key":"32e265d7-cc2a-4779-b13a-eb2e0bb7d7ed","type":"data","content":[{"type":"paragraph","text":"275","spans":[{"start":0,"end":3,"type":"strong"}],"direction":"ltr"}]}]}]}},"align_fibers_description":"RTS delivers up to 65% weight reduction compared to conventional laminates — same strength, one-third the material.","image_side_image_1":{"dimensions":{"width":1380,"height":1380},"alt":"EXTNGO - RTS","copyright":null,"url":"https://images.prismic.io/EXTNGO/aVKu-nNYClf9oran_001.png?auto=format,compress","id":"aVKu-nNYClf9oran","edit":{"x":0,"y":0,"zoom":1,"background":"transparent"}},"image_side_image_1_caption":"EXTNGO - RTS","image_side_image_2":{"dimensions":{"width":1380,"height":1380},"alt":"65% reduced weight","copyright":null,"url":"https://images.prismic.io/EXTNGO/aVKveHNYClf9ora6_002.png?auto=format,compress","id":"aVKveHNYClf9ora6","edit":{"x":0,"y":0,"zoom":1,"background":"transparent"}},"image_side_image_2_caption":"65% reduced weight","image_side_text":[{"type":"paragraph","text":"The optimal fiber orientation, at every layer, at every point of a structure. This is the power of RTS. Because with fiber steering the design space is drastically expanded, and a lighter/stronger result will always be achieved vs straight fiber.","spans":[],"direction":"ltr"}],"advantage_section_2_line1":null,"advantage_section_2_line2":"10x Faster Production","industrial_rates_title":"Steering Enables Forming, the Key to Industrial Rates","industrial_rates_heading_paragraph":"Fiber Steering is key to unlock manufacturing of complex composite parts at industrial production rates. The best way to achieve this is a forming/stamping workflow (high rate / low cost / automated workflow, validated in automotive).","industrial_rates_paragraph":"However, unlike metals which stretch in all directions, carbon fiber and composites cannot stretch in the fiber direction. This has been the main bottleneck for stamping/forming of complex composite parts. Fiber Steering adds an additional degree of freedom, enabling to pre-steer the fibers in a 2D preform, which can then be stamped without forming defects.","timeline_items":[{"image":{"dimensions":{"width":3710,"height":2475},"alt":"Forming Analysis","copyright":null,"url":"https://images.prismic.io/EXTNGO/aXt4bgIvOtkhCFB6_Picture23.png?auto=format,compress","id":"aXt4bgIvOtkhCFB6","edit":{"x":0,"y":0,"zoom":1,"background":"transparent"}},"text":"Forming Analysis"},{"image":{"dimensions":{"width":904,"height":598},"alt":"2D Preform Production","copyright":null,"url":"https://images.prismic.io/EXTNGO/aVUM1XNYClf9otn8_vv.png?auto=format,compress","id":"aVUM1XNYClf9otn8","edit":{"x":0,"y":0,"zoom":1,"background":"transparent"}},"text":"2D Preform Production"},{"image":{"dimensions":{"width":8192,"height":5464},"alt":"Stamping or Forming","copyright":null,"url":"https://images.prismic.io/EXTNGO/aYJcVt0YXLCxVVH9_EXTNGO.gloucester.2025.09-1398.fullresolution.jpg?auto=format,compress","id":"aYJcVt0YXLCxVVH9","edit":{"x":0,"y":0,"zoom":1,"background":"transparent"}},"text":"Stamping or Forming"},{"image":{"dimensions":{"width":3710,"height":2475},"alt":"Complex 3D Parts, Optimized Fiber Paths","copyright":null,"url":"https://images.prismic.io/EXTNGO/aXt4bwIvOtkhCFB7_Picture24.png?auto=format,compress","id":"aXt4bwIvOtkhCFB7","edit":{"x":0,"y":0,"zoom":1,"background":"transparent"}},"text":"Complex 3D Parts Optimized Fiber Paths"}],"video_2_title":[{"type":"paragraph","text":"By optimising both for structural and forming performance, RTS provides:\n\nthe lightest structures possible,  produced in an automated workflow and at a fraction of the cost, \ncompared to the state-of-the-art.","spans":[],"direction":"ltr"}],"video_2_desktop":{"link_type":"Media","key":"01f5dc39-7bc0-451d-aca6-5c9d7d665e6d","kind":"file","id":"aWEmzwIvOtkhBOwK","url":"https://EXTNGO.cdn.prismic.io/EXTNGO/aWEmzwIvOtkhBOwK_tech-preview.mp4","name":"tech-preview.mp4","size":"2751911"},"video_2_mobile":{"link_type":"Media","key":"68f0d5e2-ed91-4657-9482-56ab65012d31","kind":"file","id":"aWEmzwIvOtkhBOwK","url":"https://EXTNGO.cdn.prismic.io/EXTNGO/aWEmzwIvOtkhBOwK_tech-preview.mp4","name":"tech-preview.mp4","size":"2751911"},"video_2_poster":{"dimensions":{"width":1920,"height":1080},"alt":null,"copyright":null,"url":"https://images.prismic.io/EXTNGO/aWEm3QIvOtkhBOwS_tech-preview.webp?auto=format,compress","id":"aWEm3QIvOtkhBOwS","edit":{"x":0,"y":0,"zoom":1,"background":"transparent"}},"video_2_static_image":{},"video_2_thumbnail_image":{"dimensions":{"width":672,"height":406},"alt":null,"copyright":null,"url":"https://images.prismic.io/EXTNGO/aVURFnNYClf9otoy_Container4.png?auto=format,compress","id":"aVU